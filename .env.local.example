# Copy to .env.local and fill in.
# .env.local is gitignored.

# Path to mom's GEDCOM file (outside the repo, never commit)
GEDCOM_PATH=/Users/jaketaub/Downloads/Kingsbury Taub Family Tree.ged

# Mom's individual ID inside the GEDCOM (e.g. @I_348814644@)
# Required for kinship labels ("your 5x-great-grandmother")
# Build will error loudly if unset or not found in the tree.
MOM_GEDCOM_ID=

# Shared password for the middleware gate (hash via bcrypt)
# Example: echo -n "password" | openssl dgst -sha256
SHARED_PASSWORD_HASH=

# LLM features (v3+). Narrative + stories-oracle.
ANTHROPIC_API_KEY=

# Upstash Redis (rotation state for on-this-day, v2+)
KV_REST_API_URL=
KV_REST_API_TOKEN=

# Voyage AI embeddings (v4 stories-oracle only)
VOYAGE_API_KEY=
